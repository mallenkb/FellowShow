{
  "name": "fellowshow",
  "version": "0.1.23",
  "packageManager": "bun@1.3.14",
  "description": "Real-time AI-powered Bible verse detection for live sermons and broadcasts.",
  "license": "MIT",
  "homepage": "https://github.com/mallenkb/FellowShow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mallenkb/FellowShow.git"
  },
  "bugs": {
    "url": "https://github.com/mallenkb/FellowShow/issues"
  },
  "keywords": [
    "bible",
    "broadcast",
    "tauri",
    "react",
    "rust",
    "ndi",
    "speech-to-text"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "knip": "knip",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "bun run scripts/tauri.ts",
    "test": "vitest",
    "download:bible-data": "bun run data/download-sources.ts",
    "download:asante-twi": "bun run data/download-asante-twi.ts",
    "download:thiagobodruk-bibles": "bun run data/download-thiagobodruk-bibles.ts",
    "build:bible": "bun run data/build-bible-db.ts",
    "prepare:release-bible": "bun run data/prepare-release-bible.ts",
    "prepare:r2-content": "bun run data/prepare-r2-content.ts",
    "publish:r2-content": "bun run data/publish-r2-content.ts",
    "release:bundled": "bun run download:asante-twi && bun run prepare:release-bible && bun run tauri build",
    "release:r2": "bun run download:asante-twi && bun run prepare:r2-content && bun run publish:r2-content",
    "download:model": "bun run data/download-model.ts",
    "export:verses": "bun run data/compute-embeddings.ts",
    "quantize:model": "optimum-cli onnxruntime quantize --onnx_model models/qwen3-embedding-0.6b/ --arm64 -o models/qwen3-embedding-0.6b-int8/",
    "precompute:embeddings-onnx": "bun run data/run-python.ts data/precompute-embeddings-onnx.py",
    "precompute:embeddings-py": "bun run data/run-python.ts data/precompute-embeddings.py",
    "precompute:embeddings": "cd src-tauri && cargo run -p fellowshow-detection --features precompute-bin --release --bin precompute -- --model ../models/qwen3-embedding-0.6b/model.onnx --tokenizer ../models/qwen3-embedding-0.6b/tokenizer.json --verses ../data/verses-for-embedding.json --output-embeddings ../embeddings/kjv-qwen3-0.6b.bin --output-ids ../embeddings/kjv-qwen3-0.6b-ids.bin",
    "download:whisper": "bun run data/download-whisper-model.ts",
    "download:ndi-sdk": "bun run data/download-ndi-sdk.ts",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "setup:all": "bun run data/prepare-embeddings.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/geist-mono": "^5.2.8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fabric": "^7.4.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-joyride": "^3.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
