# Speech-to-text
DEEPGRAM_API_KEY=

# Cloudflare R2 publishing.
# Keep real values in .env or your CI secret store; never commit credentials.
CLOUDFLARE_API_TOKEN=
R2_BUCKET=fellow-show
R2_PREFIX=content

# Optional AWS CLI/S3-compatible upload path.
R2_UPLOAD_TOOL=wrangler
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Public read URL used by the app at runtime for translation/content downloads.
# Set either the exact manifest URL or a public base URL that contains
# /content/latest/content-manifest.json.
FELLOWSHOW_CONTENT_MANIFEST_URL=
FELLOWSHOW_CONTENT_BASE_URL=
