{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main", "broadcast", "broadcast-alt"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "opener:default",
    "updater:default",
    "fs:default",
    "fs:allow-write-text-file"
  ]
}
