{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "broadcast-output",
  "description": "Minimum permissions required by isolated broadcast output windows",
  "windows": ["broadcast", "broadcast-alt"],
  "permissions": [
    "core:default",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen"
  ]
}
